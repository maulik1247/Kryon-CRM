DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Required — app middleware and auth will fail without these on Vercel
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

NEXT_PUBLIC_CRM_API=true

# Demo client login (public — for previews only)
NEXT_PUBLIC_DEMO_USER_EMAIL=demo@kryon.com
NEXT_PUBLIC_DEMO_USER_PASSWORD=KryonDemo1!

# --- Vercel deploy checklist ---
# 1. Project → Settings → Environment Variables: copy every variable above
#    (use Production values from Clerk + Neon; skip placeholders).
# 2. Clerk Dashboard → configure → Domains: add your *.vercel.app URL
#    and production domain.
# 3. After first deploy: run `npx prisma db push` / migrate against Neon,
#    then `npm run db:seed` and `npm run setup:demo` locally pointed at prod DB.
